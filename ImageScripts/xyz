sub get_rms {
 ############################################################################
 ## Переделанная на перл coord.c Г.Сальникова
 ## Принимает две ссылки на геометрии (см. read_molden() из conformers)
 ## Возвращает RMSD между геометриями
 ## Во вторую ссылку записывает новую, сглаженную геометрию
 ## Использует глобальный хэш %massa с массами элементов (см. smooth)
 ############################################################################
  my ($mol0, $mol1) = @_;
  my ($i, $n, $rot);
  my (@m, @x0, @y0, @z0, @x1, @y1, @z1, $xc, $yc, $zc, $e, $e0,
		$mtot, $tg1, $tg2, $phi, $phix, $phiy, $phiz);
  my $M_PI = atan2(0,-1);
  my $FLT_EPSILON = 1e-12;
  #my $debug = 0;
  
  #/*** Input data preparation ***/
  $n = $#{$mol0};
  for ($i=0; $i<$n; $i++) {
    $m[$i] = $massa{$mol0->[$i+1][0]};
    die "Inconsistent data\n" if $massa{$mol1->[$i+1][0]} != $m[$i];
    $mtot += $m[$i];
    $x0[$i] = $mol0->[$i+1][1];
    $y0[$i] = $mol0->[$i+1][2];
    $z0[$i] = $mol0->[$i+1][3];
    $x1[$i] = $mol1->[$i+1][1];
    $y1[$i] = $mol1->[$i+1][2];
    $z1[$i] = $mol1->[$i+1][3];
  }
  
  #/*** 1-st translation to center of mass ***/

  $xc = $yc = $zc = 0;
  for ($i=0; $i<$n; $i++)
  {
    $xc += $m[$i]*$x0[$i];
    $yc += $m[$i]*$y0[$i];
    $zc += $m[$i]*$z0[$i];
  }
  $xc /= $mtot;
  $yc /= $mtot;
  $zc /= $mtot;

  for ($i=0; $i<$n; $i++)
  {
    $x0[$i] -= $xc;
    $y0[$i] -= $yc;
    $z0[$i] -= $zc;
  }

  if ($debug) {
    printf ("1-st molecule in center of mass\n");
    for ($i=0; $i<$n; $i++) {
      printf "%2.0f   %10f   %10f   %10f\n", $m[$i], 
              $x0[$i], $y0[$i], $z0[$i];
    }
    printf "1-st center of mass translation on: (%10f, %10f, %10f)\n",
	          -$xc, -$yc, -$zc;
  }

  #/*** 2-nd translation to center of mass ***/

  $xc = $yc = $zc = 0;
  for ($i=0; $i<$n; $i++)
  {
    $xc += $m[$i]*$x1[$i];
    $yc += $m[$i]*$y1[$i];
    $zc += $m[$i]*$z1[$i];
  }
  $xc /= $mtot;
  $yc /= $mtot;
  $zc /= $mtot;

  for ($i=0; $i<$n; $i++)
  {
    $x1[$i] -= $xc;
    $y1[$i] -= $yc;
    $z1[$i] -= $zc;
  }

  if ($debug) {
    printf ("2-nd molecule in center of mass\n");
    for ($i=0; $i<$n; $i++) {
      printf "%2.0f   %10f   %10f   %10f\n", 
              $m[$i], $x1[$i], $y1[$i], $z1[$i];
    }
    printf "2-nd center of mass translation on: (%10f, %10f, %10f)\n",
	          -$xc, -$yc, -$zc;
  }

  $e = 0;
  for ($i=0; $i<$n; $i++) {
    $e += $m[$i]*(($x1[$i]-$x0[$i])*($x1[$i]-$x0[$i])+
	       ($y1[$i]-$y0[$i])*($y1[$i]-$y0[$i])+
	       ($z1[$i]-$z0[$i])*($z1[$i]-$z0[$i]));
  }
  printf ("2*energy: %g\n", $e) if $debug;

  for ($rot=1; ; $rot++)
  {
    $e0 = $e;

    #/*** Rotation around X ***/

    $tg1 = $tg2 = 0;
    for ($i=0; $i<$n; $i++)
    {
      $tg1 += $m[$i]*($y0[$i]*$z1[$i]-$z0[$i]*$y1[$i]);
      $tg2 += $m[$i]*($y0[$i]*$y1[$i]+$z0[$i]*$z1[$i]);
    }
    $phi = atan2 ($tg1, $tg2);

    for ($i=0; $i<$n; $i++)
    {
      $yc = $y1[$i]*cos($phi)+$z1[$i]*sin($phi);
      $zc = $z1[$i]*cos($phi)-$y1[$i]*sin($phi);
      $y1[$i] = $yc;
      $z1[$i] = $zc;
    }

    $e = 0;
    for ($i=0; $i<$n; $i++) {
      $e += $m[$i]*(($x1[$i]-$x0[$i])*($x1[$i]-$x0[$i])+
		 ($y1[$i]-$y0[$i])*($y1[$i]-$y0[$i])+
		 ($z1[$i]-$z0[$i])*($z1[$i]-$z0[$i]));
    }
    if ($debug) {
      for ($i=0; $i<$n; $i++) {
        printf "%2.0f   %10f   %10f   %10f\n", 
                $m[$i], $x1[$i], $y1[$i], $z1[$i];
      }
      printf "after %d-th rotation around X on: %g (%g deg)\n2*energy: %g\n",
	            $rot, $phi, $phi*180/$M_PI, $e;
    }

    $phix = $phi;

    #/*** Rotation around Y ***/

    $tg1 = $tg2 = 0;
    for ($i=0; $i<$n; $i++)
    {
      $tg1 += $m[$i]*($z0[$i]*$x1[$i]-$x0[$i]*$z1[$i]);
      $tg2 += $m[$i]*($z0[$i]*$z1[$i]+$x0[$i]*$x1[$i]);
    }
    $phi = atan2 ($tg1, $tg2);

    for ($i=0; $i<$n; $i++)
    {
      $xc = $x1[$i]*cos($phi)-$z1[$i]*sin($phi);
      $zc = $z1[$i]*cos($phi)+$x1[$i]*sin($phi);
      $x1[$i] = $xc;
      $z1[$i] = $zc;
    }

    $e = 0;
    for ($i=0; $i<$n; $i++) {
      $e += $m[$i]*(($x1[$i]-$x0[$i])*($x1[$i]-$x0[$i])+
		 ($y1[$i]-$y0[$i])*($y1[$i]-$y0[$i])+
		 ($z1[$i]-$z0[$i])*($z1[$i]-$z0[$i]));
    }
    if ($debug) {
      for ($i=0; $i<$n; $i++) {
        printf "%2.0f   %10f   %10f   %10f\n", 
                $m[$i], $x1[$i], $y1[$i], $z1[$i];
      }
      printf "after %d-th rotation around Y on: %g (%g deg)\n2*energy: %g\n",
	            $rot, $phi, $phi*180/$M_PI, $e;
    }

    $phiy = $phi;

    #/*** Rotation around Z ***/

    $tg1 = $tg2 = 0;
    for ($i=0; $i<$n; $i++)
    {
      $tg1 += $m[$i]*($x0[$i]*$y1[$i]-$y0[$i]*$x1[$i]);
      $tg2 += $m[$i]*($x0[$i]*$x1[$i]+$y0[$i]*$y1[$i]);
    }
    $phi = atan2 ($tg1, $tg2);

    for ($i=0; $i<$n; $i++)
    {
      $xc = $x1[$i]*cos($phi)+$y1[$i]*sin($phi);
      $yc = $y1[$i]*cos($phi)-$x1[$i]*sin($phi);
      $x1[$i] = $xc;
      $y1[$i] = $yc;
    }

    $e = 0;
    for ($i=0; $i<$n; $i++) {
      $e += $m[$i]*(($x1[$i]-$x0[$i])*($x1[$i]-$x0[$i])+
		 ($y1[$i]-$y0[$i])*($y1[$i]-$y0[$i])+
		 ($z1[$i]-$z0[$i])*($z1[$i]-$z0[$i]));
    }
    if ($debug) {
      for ($i=0; $i<$n; $i++) {
        printf "%2.0f   %10f   %10f   %10f\n", 
               $m[$i], $x1[$i], $y1[$i], $z1[$i];
      }
      printf "after %d-th rotation around Z on: %g (%g deg)\n2*energy: %g\n",
	      $rot, $phi, $phi*180/$M_PI, $e;
    }

    $phiz = $phi;

    #print "$phix $phiy $phiz\n";
    #print abs(($e-$e0)/($e+$e0)), "\n";
    #print "$e == $e0\n";
    last if (abs($phix) < $FLT_EPSILON &&
	           abs($phiy) < $FLT_EPSILON &&
	           abs($phiz) < $FLT_EPSILON &&
	           ($e == $e0 || abs($e+$e0) < $FLT_EPSILON || (abs(($e-$e0)/($e+$e0)) < $FLT_EPSILON)));
  }

  #/*** Output data preparation ***/

  for ($i=0; $i<$n; $i++) {
    $mol1->[$i+1][1] = $x1[$i];
    $mol1->[$i+1][2] = $y1[$i];
    $mol1->[$i+1][3] = $z1[$i];
  }
  if ($debug) {
    for ($i=0; $i<$n; $i++) {
      printf "%2.0f   %10f   %10f   %10f\n", $m[$i], $x1[$i], $y1[$i], $z1[$i];
    }
    printf "2*energy: %g\n", $e;
  }

  #/*** Finished ***/
  
  return sqrt($e);
#  return $e;
}

sub irc_like {
  my $rms = shift;
  my @mol = (shift);
  my $count = 1;
  foreach (@_) {
    if ($count == @_) {
      push @mol,$_ if $_->[0]{Energy} <= $mol[-1][0]{Energy};
      last;
    }
    next if $_->[0]{Energy} > $mol[-1][0]{Energy};
    my $rrr = $rms==0 ? 1e6 : get_rms($mol[-1],$_);
    next if $rrr <= $rms;
    push @mol,$_;
    $count++;
  }
  return @mol; 
}

sub content {
  my $T = shift;
  my $unit = shift;
  my @mols = @_;
  #pp @mols;
  
  my @en; 
  my $min = 1e18;
  foreach my $mol (@mols) {
    my $e = $mol->[0]{Energy};
    return unless defined $e;
    push @en, $e;
    $min = $e if $min>$e;
  }
  @en = map {$_-$min} @en;
  #pp @en;
  
  my (@fract,$sum);
  foreach (@en) {
    my $f = exp(-$_*$unit*1000/1.9872/$T);
    push @fract, $f;
    $sum += $f;
  }
  @fract = map {$_/$sum} @fract;
  
  for (my $i=0; $i<@mols; $i++) {
    $mols[$i][0]{Content} = sprintf "%.6f", $fract[$i];
  }
  
  return @mols;
}

sub no_hide {
  my $mol = shift;
  return unless $mol;
  my $step = 15;
  my $rot = 90;
  to_centre_mass($mol);
  my $mol_best;
  
  my $bonds;
  if ($no_hide==10) {
    for (my $i=1; $i<@$mol; $i++) {
      next if $no_H && $mol->[$i][0] eq 'H';
      my ($xi,$yi,$zi) = @{$mol->[$i]}[1..3];
      for (my $j=$i+1; $j<@$mol; $j++) {
        next if $no_H && $mol->[$j][0] eq 'H';
        my ($xj,$yj,$zj) = @{$mol->[$j]}[1..3];
        ($xi-$xj)**2+($yi-$yj)**2+($zi-$zj)**2 < 3.6 && 
        push @$bonds, [$i,$j];
      }
    }
  }
  
  # Ищем глобальный минимум критерия по вращению вокруг осей x,у
  # Тупо перебором во всем интервале -rot..rot (есть локальные минимумы)
  my $n = $rot/$step;
  my @crits;
  my $angle_best;
  my $crit_min = 1e9;
  #my $crit_max = 0;
  for (my $i=0; $i<=2*$n; $i++) {
    my $ax = $i*$step - $rot;
    my $molx = rot_x($mol,$ax);
    for (my $j=0; $j<=2*$n; $j++) {
      my $ay = $j*$step - $rot;
      my $molxy = rot_y($molx,$ay);
      my $crit;
      if    ($no_hide==1) {$crit = crit1($molxy)}
      elsif ($no_hide==10) {$crit = crit1($molxy,$bonds)}
      elsif ($no_hide==2) {$crit = crit2($molxy)}
      elsif ($no_hide==3) {$crit = crit3($molxy)}
      else {die "Ivalid value of -no_hide\n"};
      #printf STDERR "%5.0f",$crit;
      $crits[$i][$j] = $crit; # На всякий случай
      if ($crit < $crit_min) {
        $crit_min = $crit;
        $angle_best = [$ax,$ay];
        $mol_best = $molxy;
      }
    }
    #warn "\n";
  }
  
  # Спускаемся из окрестностей глобального минимума в сам минимум
  my %crit;
  my ($I,$J) = (0,0);
  $max_rot = $step;
  $step = 1;
  my $max_ij = $max_rot/$step;
  
  if    ($no_hide==1) {$crit{"0,0"} = crit1($mol_best)}
  elsif ($no_hide==10) {$crit{"0,0"} = crit1($mol_best,$bonds)}
  elsif ($no_hide==2) {$crit{"0,0"} = crit2($mol_best)}
  elsif ($no_hide==3) {$crit{"0,0"} = crit3($mol_best)}
  else {die "Ivalid value of -no_hide\n"};
  while (1) {
    my $crit_min = 1e6;
    my ($i_min,$j_min) = ($I,$J);
    foreach ([$I,$J+1],[$I+1,$J],[$I,$J-1],[$I-1,$J]) {
      my ($i,$j) = @$_;
      next if defined $crit{"$i,$j"};
      next if abs($i)>=$max_ij || abs($j)>=$max_ij;
      my $mol1 = rot_y($mol_best, $i*$step);
      $mol1 = rot_x($mol1, $j*$step);
      if    ($no_hide==1) {$crit{"$i,$j"} = crit1($mol1)}
      elsif ($no_hide==10) {$crit{"$i,$j"} = crit1($mol1,$bonds)}
      elsif ($no_hide==2) {$crit{"$i,$j"} = crit2($mol1)}
      elsif ($no_hide==3) {$crit{"$i,$j"} = crit3($mol1)}
      #printf STDERR "%4d %4d %8.2f\n", $i*$step, $j*$step, crit2($mol1);
      if ($crit{"$i,$j"} < $crit_min) {
        $crit_min = $crit{"$i,$j"};
        $i_min = $i;
        $j_min = $j;
#        $mol_best = $mol1;
      }
    }
    if ($crit_min < $crit{"$I,$J"}) {
      $I = $i_min;
      $J = $j_min;
      #printf STDERR "%4d %4d %8.2f\n", $I*$step, $J*$step, $crit{"$I,$J"};
    }
    else {
      #write_molden($mol_best);
      $mol_best = rot_y($mol_best, $I*$step);
      $mol_best = rot_x($mol_best, $J*$step);
      last;
    }
  }

  return $mol_best;
}
sub crit1 {
 # Сумма 1/r по всем парам атомов
  my ($mol,$bonds) = @_;
  my $sum;
  for (my $i=1; $i<@$mol; $i++) {
    next if $no_H && $mol->[$i][0] eq 'H';
    for (my $j=$i+1; $j<@$mol; $j++) {
      next if $no_H && $mol->[$j][0] eq 'H';
      my $r = distxy($mol,$i,$j);
      $r = 0.01 if $r<0.01;
      $sum += 1/$r;
    }
    if ($bonds) {
      foreach (@$bonds) {
        my ($j,$k) = @$_;
        next if $i==$j or $i==$k;
        next if distxy($mol,$i,$j) > 1 && distxy($mol,$i,$k) > 1;
        # Bond proection (xj,yj)-(xk,yk)
        my ($xj,$yj) = ($mol->[$j][1], $mol->[$j][2]);
        my ($xk,$yk) = ($mol->[$k][1], $mol->[$k][2]);
        # Atom proection (xi,yi)
        my ($xi,$yi) = ($mol->[$i][1], $mol->[$i][2]);
        # Perpendicular from atom to bond
        my $xkj = $xk-$xj;
        my $ykj = $yk-$yj;
        my $x = ($xkj*$ykj*($yi-$yj)+$xj*$ykj**2+$xi*$xkj**2) / ($ykj**2+$xkj**2);
        my $y = $ykj*($x-$xj)/$xkj+$yj;
        # Точка пересечения перпендикуляра с связью должна лежать на связи
        next if ($x-$xj)/($x-$xk)>0 or ($y-$yj)/($y-$yk)>0;
  #      next if $xj<$xk ? ($x<$xj || $x>$xk) : ($x>$xj || $x<$xk) or
  #              $yj<$yk ? ($y<$yj || $y>$yk) : ($y>$yj || $y<$yk);
        # Длина перпендикуляра
        my $r = sqrt(($x-$xi)**2+($y-$yi)**2);
        $r = 0.01 if $r<0.01;
        $sum += 1/$r;
      }
    }
  }
  return $sum;
}
sub crit2 {
 # Минимальное расстояние между атомами в проекции xy
  my $mol = shift;
  my $rmin = 100;
  for (my $i=1; $i<@$mol; $i++) {
    for (my $j=$i+1; $j<@$mol; $j++) {
      my $r = distxy($mol,$i,$j);
      if ($r < $rmin) {
        $rmin = $r;
      }
    }
  }
  return -$rmin;
}
sub crit3 {
 # Сумма черных пикселов
  my $mol = shift;
  my $sum = 0;
  my $rH = 0.49/2; # Радиус Н
  my $rC = 0.65/2; # Радиус С
  #my $rB = 0.38; # Толщина связи
  my $step = 0.05; # ~10 points per H
  
  my ($x_max,$y_max,$x_min,$y_min) = (-1e9,-1e9,1e9,1e9);
  for (my $i=1; $i<@$mol; $i++) {
    next if $no_H && $mol->[$i][0] eq 'H';
    $x_max = $mol->[$i][1] if $x_max < $mol->[$i][1];
    $y_max = $mol->[$i][2] if $y_max < $mol->[$i][2];
    $x_min = $mol->[$i][1] if $x_min > $mol->[$i][1];
    $y_min = $mol->[$i][2] if $y_min > $mol->[$i][2];
  }
  #print "$x_max,$y_max,$x_min,$y_min\n"; exit;
  
  my $R = $no_H ? $rC/2 : $rH/2;
  my $X_min = $x_min - $R;
  my $X_max = $x_max + $R;
  my $Y_min = $y_min - $R;
  my $Y_max = $y_max + $R;
  
  for (my $x=$X_min; $x<=$X_max; $x+=$step) {
    for (my $y=$Y_min; $y<=$Y_max; $y+=$step) {
      #printf STDERR "%6.2f %6.2f\n", $x, $y;
      for (my $i=1; $i<@$mol; $i++) {
        my $r = sqrt(($x-$mol->[$i][1])**2+($y-$mol->[$i][2])**2);
        if ( $r <= ($mol->[$i][0] eq 'H' ? $rH : $rC) ) {
          $sum++;
          last;
        }
      }
    }
  }
  return -$sum;
}
sub distxy {
  my ($mol,$i,$j) = @_;
  my $rij = sqrt(($mol->[$i][1]-$mol->[$j][1])**2 +
                 ($mol->[$i][2]-$mol->[$j][2])**2 );
  return $rij;
}
sub dist2 {
  my ($mol,$i,$j) = @_;
  my $r2 = ($mol->[$i][1]-$mol->[$j][1])**2 +
           ($mol->[$i][2]-$mol->[$j][2])**2 +
           ($mol->[$i][3]-$mol->[$j][3])**2;
  return $r2;
}
sub rot_x {
  my ($mol,$degrees) = @_;
  my @mol1 = ($mol->[0]);
  my $rad = $degrees/180*3.14159265358979;
  my $cos = cos($rad);
  my $sin = sin($rad);
  for (my $i=1; $i<@$mol; $i++) {
    my ($y,$z) = ($mol->[$i][2],$mol->[$i][3]);
    $mol1[$i][0] = $mol->[$i][0];
    $mol1[$i][1] = $mol->[$i][1];
    $mol1[$i][2] = $sin*$z+$cos*$y;
    $mol1[$i][3] = $cos*$z-$sin*$y;
  }
  return \@mol1;
}
sub rot_y {
  my ($mol,$degrees) = @_;
  my @mol1 = ($mol->[0]);
  my $rad = $degrees/180*3.14159265358979;
  my $cos = cos($rad);
  my $sin = sin($rad);
  for (my $i=1; $i<@$mol; $i++) {
    my ($x,$z) = ($mol->[$i][1],$mol->[$i][3]);
    $mol1[$i][0] = $mol->[$i][0];
    $mol1[$i][1] = $cos*$x-$sin*$z;
    $mol1[$i][2] = $mol->[$i][2];
    $mol1[$i][3] = $sin*$x+$cos*$z;
  }
  return \@mol1;
}
