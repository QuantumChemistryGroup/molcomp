  );
  
  my @Hs;
  foreach my $i (@vector) {
    next if $mol->[$i][0] eq 'H';
    for (my $j=1; $j<@$mol; $j++) {
      next if $mol->[$j][0] ne 'H';
      next if $i==$j;
      if (! exists $radius{$mol->[$j][0]}) {
